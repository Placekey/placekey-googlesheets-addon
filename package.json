  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "eslint": "^10.0.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.2.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
